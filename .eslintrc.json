{
  "root": true,
  "extends": ["next/core-web-vitals"],
  "rules": {
    "import/no-anonymous-default-export": [
      "error",
      {
        "allowObject": true
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/*.test.js",
        "**/*.test.jsx",
        "**/*.spec.js",
        "**/*.spec.jsx",
        "jest.setup.js"
      ],
      "extends": ["plugin:jest/recommended"]
    }
  ]
}
